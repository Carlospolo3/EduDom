@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Horario - Sistema EDUDOM</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #F5F5F5;
            color: #333;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: #046BCD;
            color: #FFFFFF;
            padding: 20px;
            box-shadow: 2px 0 5px rgba(0,0,0,0.2);
            overflow-y: auto;
            transition: width 0.3s ease;
        }

            .sidebar .logo {
                font-size: 24px;
                font-weight: bold;
                margin-bottom: 20px;
                text-align: center;
                color: #FFFFFF;
            }

            .sidebar a {
                display: block;
                color: #FFFFFF;
                padding: 10px;
                text-decoration: none;
                font-size: 16px;
                border-radius: 4px;
                transition: background 0.3s ease, color 0.3s ease;
            }

                .sidebar a:hover {
                    background: #FFFFFF;
                    color: #046BCD;
                }

            .sidebar .btn-close {
                background-color: #FF4D4D;
                color: #FFFFFF;
                border: none;
                padding: 10px;
                border-radius: 4px;
                cursor: pointer;
                font-size: 16px;
                text-align: center;
                transition: background-color 0.3s ease;
                margin-top: 20px;
            }

                .sidebar .btn-close:hover {
                    background-color: #CC0000;
                }

        .header {
            position: fixed;
            top: 0;
            left: 250px;
            width: calc(100% - 250px);
            background: #046BCD;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 1000;
            color: #FFFFFF;
        }

            .header .logo {
                font-size: 24px;
                font-weight: bold;
            }

            .header .search-bar input {
                padding: 8px;
                border: 1px solid #D3D3D3;
                border-radius: 4px;
                width: 300px;
            }

            .header .notifications, .header .user-avatar, .header .date-time {
                margin-left: 20px;
            }

                .header .notifications .icon {
                    font-size: 20px;
                    color: #FFFFFF;
                }

                .header .user-avatar img {
                    width: 40px;
                    height: 40px;
                    border-radius: 50%;
                    border: 2px solid #FFFFFF;
                }

            .header .date-time {
                font-size: 16px;
            }

        .main-content {
            margin-left: 250px;
            padding: 20px;
            padding-top: 80px;
        }

        .form-section {
            background: #FFFFFF;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

            .form-section h2 {
                margin-bottom: 20px;
            }

        .table-section {
            margin-top: 20px;
        }

            .table-section table {
                width: 100%;
                background: #FFFFFF;
                border-radius: 8px;
                box-shadow: 0 2px 5px rgba(0,0,0,0.2);
                overflow: hidden;
            }

            .table-section th {
                background: #046BCD;
                color: #FFFFFF;
            }

            .table-section td {
                text-align: center;
                padding: 15px;
                border: 1px solid #ddd;
            }

            .table-section .day-header {
                background-color: #046BCD;
                color: #FFFFFF;
                font-weight: bold;
            }

            .table-section .day-column {
                background-color: #FAFAFA;
            }

            .table-section input[type="text"], .table-section input[type="time"] {
                width: 100%;
                border: 1px solid #ddd;
                border-radius: 4px;
                padding: 8px;
            }

        .btn-update, .btn-add, .btn-pdf {
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            text-align: center;
            transition: background-color 0.3s ease;
            margin-top: 10px;
        }

        .btn-update {
            background-color: #4CAF50;
            color: #FFFFFF;
        }

            .btn-update:hover {
                background-color: #45a049;
            }

        .btn-add {
            background-color: #2196F3;
            color: #FFFFFF;
        }

            .btn-add:hover {
                background-color: #1E88E5;
            }

        .btn-pdf {
            background-color: #FF5722;
            color: #FFFFFF;
        }

            .btn-pdf:hover {
                background-color: #E64A19;
            }

        .row-template {
            display: none;
        }

    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">Sistema EDUDOM</div>
        <a href="/Home" class="nav-link"><i class="fas fa-home"></i>Inicio</a>
        <a href="/Profile" class="nav-link"><i class="fas fa-user"></i>Perfil</a>
        <a href="/Assignment/Index" class="nav-link"><i class="fas fa-tasks"></i>Tareas</a>
        <a href="/Cours/Index" class="nav-link"><i class="fas fa-chalkboard-teacher"></i>Aulas</a>
        <a href="/Qualifications/Index" class="nav-link"><i class="fas fa-star"></i>Calificaciones</a>
        <a href="/Attendance/Index" class="nav-link"><i class="fas fa-user-check"></i>Registro de Asistencia</a>
        <a href="/Reports/Index" class="nav-link"><i class="fas fa-chart-line"></i>Informe de Progreso</a>
        <a href="/Employeer/Index" class="nav-link"><i class="fas fa-users"></i>Empleados</a>
        <a href="/Department/Index" class="nav-link"><i class="fas fa-building"></i>Departamentos</a>
        <a href="/Distric/Index" class="nav-link"><i class="fas fa-map-marker-alt"></i>Distritos</a>
        <a href="/Province/Index" class="nav-link"><i class="fas fa-map"></i>Provincias</a>
        <a href="/School/Index" class="nav-link"><i class="fas fa-school"></i>Escuelas</a>
        <a href="/Subject/Index" class="nav-link"><i class="fas fa-book"></i>Asignaturas</a>
        <a href="/Schedule" class="nav-link"><i class="fas fa-calendar-alt"></i>Horario</a>
        <a href="/Messages" class="nav-link"><i class="fas fa-envelope"></i>Mensajes</a>
        <a href="/Support" class="nav-link"><i class="fas fa-life-ring"></i>Soporte</a>
        <button class="btn-close" onclick="goToLogin()">Cerrar Sección</button>
    </div>
    <div class="header">
        <div class="logo">Sistema EDUDOM</div>
        <div class="search-bar">
            <input type="text" placeholder="Buscar...">
        </div>
        <div class="notifications">
            <i class="fas fa-bell icon"></i>
        </div>
        <div class="user-avatar">
            <img src="https://via.placeholder.com/40" alt="User Avatar">
        </div>
        <div class="date-time">
            <div id="current-date"></div>
            <div id="current-time"></div>
        </div>
    </div>
    <div class="main-content">
        <div class="form-section">
            <h2>Horario de Clases</h2>
            <div class="table-section">
                <table id="schedule-table" class="table">
                    <thead>
                        <tr>
                            <th>Hora</th>
                            <th>Lunes</th>
                            <th>Martes</th>
                            <th>Miércoles</th>
                            <th>Jueves</th>
                            <th>Viernes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Fila de ejemplo -->
                        <tr class="row-template">
                            <td><input type="text" placeholder="Hora"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                        </tr>
                        <!-- Filas iniciales -->
                        <tr>
                            <td><input type="text" placeholder="Hora"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                            <td><input type="text" placeholder="Clase"></td>
                        </tr>
                    </tbody>
                </table>
                <button class="btn-add" onclick="addRow()">Agregar Fila</button>
                <button class="btn-update">Actualizar Horario</button>
                <button class="btn-pdf">Generar PDF</button>
            </div>
        </div>
    </div>
    <script>
        // Función para agregar una nueva fila a la tabla
        function addRow() {
            const tableBody = document.querySelector('#schedule-table tbody');
            const rowTemplate = document.querySelector('.row-template');
            const newRow = rowTemplate.cloneNode(true);
            newRow.classList.remove('row-template');
            newRow.style.display = '';
            tableBody.appendChild(newRow);
        }

        // Función para redirigir a la página de login
        function goToLogin() {
            window.location.href = '/Login';
        }

        // Actualizar fecha y hora
        function updateDateTime() {
            const dateElement = document.getElementById('current-date');
            const timeElement = document.getElementById('current-time');
            const now = new Date();
            const optionsDate = { year: 'numeric', month: 'long', day: 'numeric' };
            const optionsTime = { hour: '2-digit', minute: '2-digit', second: '2-digit' };
            dateElement.textContent = now.toLocaleDateString('es-ES', optionsDate);
            timeElement.textContent = now.toLocaleTimeString('es-ES', optionsTime);
        }
        setInterval(updateDateTime, 1000); // Actualizar cada segundo
        updateDateTime(); // Actualizar al cargar la página
    </script>
</body>
</html>
