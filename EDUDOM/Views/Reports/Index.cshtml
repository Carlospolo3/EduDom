@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema EDUDOM</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #F5F5F5;
            color: #333;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: #046BCD;
            color: #FFFFFF;
            padding: 20px;
            box-shadow: 2px 0 5px rgba(0,0,0,0.2);
            overflow-y: auto;
            transition: width 0.3s ease;
            z-index: 1000;
        }

            .sidebar .logo {
                font-size: 26px;
                font-weight: bold;
                margin-bottom: 30px;
                text-align: center;
                color: #FFFFFF;
            }

            .sidebar a {
                display: block;
                color: #FFFFFF;
                padding: 15px;
                text-decoration: none;
                font-size: 16px;
                border-radius: 6px;
                transition: background 0.3s ease, color 0.3s ease;
            }

                .sidebar a:hover {
                    background: #0D6EFD;
                    color: #FFFFFF;
                }

            .sidebar .btn-close {
                background-color: #FF4D4D;
                color: #FFFFFF;
                border: none;
                padding: 12px;
                border-radius: 6px;
                cursor: pointer;
                font-size: 16px;
                text-align: center;
                transition: background-color 0.3s ease;
                margin-top: 30px;
                width: 100%;
                box-shadow: 0 4px 6px rgba(0,0,0,0.2);
            }

                .sidebar .btn-close:hover {
                    background-color: #CC0000;
                }

        .header {
            position: fixed;
            top: 0;
            left: 250px;
            width: calc(100% - 250px);
            background: #046BCD;
            color: #FFFFFF;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            padding: 15px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 1000;
            border-bottom: 2px solid #0D6EFD;
        }

            .header .logo {
                font-size: 26px;
                font-weight: bold;
            }

            .header .search-bar input {
                padding: 10px;
                border: 1px solid #D3D3D3;
                border-radius: 4px;
                width: 300px;
                font-size: 16px;
            }

            .header .notifications, .header .user-avatar, .header .date-time {
                margin-left: 20px;
            }

                .header .notifications .icon {
                    font-size: 24px;
                    color: #FFFFFF;
                    cursor: pointer;
                }

                .header .user-avatar img {
                    width: 45px;
                    height: 45px;
                    border-radius: 50%;
                    border: 2px solid #FFFFFF;
                    cursor: pointer;
                }

            .header .date-time {
                font-size: 18px;
            }

        .main-content {
            margin-left: 250px;
            padding: 20px;
            padding-top: 100px;
        }

        .card {
            background: #FFFFFF;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            padding: 25px;
            transition: box-shadow 0.3s ease;
        }

            .card:hover {
                box-shadow: 0 6px 12px rgba(0,0,0,0.2);
            }

            .card h2 {
                margin-bottom: 20px;
                font-size: 24px;
                color: #046BCD;
                font-weight: 600;
            }

            .card p {
                font-size: 18px;
                line-height: 1.6;
                color: #555555;
            }

        .statistics-card, .chart-card, .notifications-card {
            margin-bottom: 30px;
        }

        .chart-card {
            position: relative;
        }

            .chart-card .chart-container {
                height: 300px;
            }

        .notifications-card {
            background: #FFFFFF;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            padding: 20px;
            border-left: 5px solid #046BCD;
        }

            .notifications-card h2 {
                font-size: 20px;
                font-weight: 600;
                margin-bottom: 15px;
            }

        .notification-item {
            display: flex;
            align-items: center;
            padding: 10px;
            border-bottom: 1px solid #D3D3D3;
        }

            .notification-item:last-child {
                border-bottom: none;
            }

            .notification-item i {
                font-size: 24px;
                color: #046BCD;
                margin-right: 15px;
            }

            .notification-item p {
                font-size: 16px;
                color: #555555;
            }

        .filter-card {
            margin-bottom: 30px;
            background: #FFFFFF;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            padding: 20px;
        }

            .filter-card h2 {
                font-size: 20px;
                font-weight: 600;
                margin-bottom: 15px;
            }

            .filter-card .form-group {
                margin-bottom: 15px;
            }

                .filter-card .form-group label {
                    font-size: 16px;
                    font-weight: 500;
                }

                .filter-card .form-group select {
                    width: 100%;
                    padding: 10px;
                    border: 1px solid #D3D3D3;
                    border-radius: 4px;
                    font-size: 16px;
                }

    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">Sistema EDUDOM</div>
        <a href="/Home" class="nav-link"><i class="fas fa-home"></i>Inicio</a>
        <a href="/Profile" class="nav-link"><i class="fas fa-user"></i>Perfil</a>
        <a href="/Assignment/Index" class="nav-link"><i class="fas fa-tasks"></i>Tareas</a>
        <a href="/Cours/Index" class="nav-link"><i class="fas fa-chalkboard-teacher"></i>Aulas</a>
        <a href="/Qualifications/Index" class="nav-link"><i class="fas fa-star"></i>Calificaciones</a>
        <a href="/Attendance/Index" class="nav-link"><i class="fas fa-user-check"></i>Registro de Asistencia</a>
        <a href="/Reports" class="nav-link"><i class="fas fa-chart-line"></i>Informe de Progreso</a>
        <a href="/Employeer/Index" class="nav-link"><i class="fas fa-users"></i>Empleados</a>
        <a href="/Department/Index" class="nav-link"><i class="fas fa-building"></i>Departamentos</a>
        <a href="/Distric/Index" class="nav-link"><i class="fas fa-map-marker-alt"></i>Distritos</a>
        <a href="/School/Index" class="nav-link"><i class="fas fa-school"></i>Escuelas</a>
        <a href="/Subject/Index" class="nav-link"><i class="fas fa-book"></i>Asignaturas</a>
        <a href="/Schedule" class="nav-link"><i class="fas fa-calendar-alt"></i>Horario</a>
        <a href="/Messages" class="nav-link"><i class="fas fa-envelope"></i>Mensajes</a>
        <a href="/Province/Index" class="nav-link"><i class="fas fa-map"></i>Provincias</a>
        <button class="btn-close" onclick="goToLogin()">Cerrar Sesión</button>
    </div>
    <div class="header">
        <div class="logo">Sistema EDUDOM</div>
        <div class="search-bar">
            <input type="text" placeholder="Buscar...">
        </div>
        <div class="notifications">
            <i class="fas fa-bell"></i>
        </div>
        <div class="user-avatar">
            <img src="https://via.placeholder.com/45" alt="User Avatar">
        </div>
        <div class="date-time" id="currentDateTime"></div>
    </div>
    <div class="main-content">
        <div class="filter-card card">
            <h2>Filtros</h2>
            <div class="form-group">
                <label for="schoolSelect">Escuela:</label>
                <select id="schoolSelect">
                    <option value="">Todas las Escuelas</option>
                    <!-- Opciones de escuelas aquí -->
                </select>
            </div>
            <div class="form-group">
                <label for="provinceSelect">Provincia:</label>
                <select id="provinceSelect">
                    <option value="">Todas las Provincias</option>
                    <!-- Opciones de provincias aquí -->
                </select>
            </div>
            <div class="form-group">
                <label for="districtSelect">Distrito:</label>
                <select id="districtSelect">
                    <option value="">Todos los Distritos</option>
                    <!-- Opciones de distritos aquí -->
                </select>
            </div>
        </div>
        <div class="statistics-card card">
            <div class="row">
                <div class="col-md-4">
                    <div class="card">
                        <h4>Cantidad de Alumnos</h4>
                        <p>150</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <h4>Promedio de Asistencias</h4>
                        <p>88%</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <h4>Promedio de Inasistencia</h4>
                        <p>5%</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="chart-card card">
            <h2>Gráfico de Progreso</h2>
            <div class="chart-container">
                <canvas id="progressChart"></canvas>
            </div>
        </div>
        <div class="notifications-card card">
            <h2>Notificaciones</h2>
            <div class="notification-item">
                <i class="fas fa-info-circle"></i>
                <p>Nuevo mensaje de la administración.</p>
            </div>
            <div class="notification-item">
                <i class="fas fa-calendar-check"></i>
                <p>Revisión de tareas completadas esta semana.</p>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function goToLogin() {
            window.location.href = '/Account/Login';
        }

        function updateDateTime() {
            const now = new Date();
            const options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', weekday: 'long' };
            document.getElementById('currentDateTime').textContent = now.toLocaleDateString('es-ES', options);
        }

        setInterval(updateDateTime, 1000);

        // Configuración del gráfico
        const ctx = document.getElementById('progressChart').getContext('2d');
        const progressChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo'],
                datasets: [{
                    label: 'Progreso Mensual',
                    data: [10, 20, 15, 25, 30],
                    backgroundColor: 'rgba(0, 123, 255, 0.5)',
                    borderColor: 'rgba(0, 123, 255, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
</body>
</html>
