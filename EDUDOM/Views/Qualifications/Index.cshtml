@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asignar Calificación - Sistema EDUDOM</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #F5F5F5;
            color: #333;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: #046BCD;
            color: #FFFFFF;
            padding: 20px;
            box-shadow: 2px 0 5px rgba(0,0,0,0.2);
            overflow-y: auto;
            transition: width 0.3s ease;
        }

            .sidebar .logo {
                font-size: 24px;
                font-weight: bold;
                margin-bottom: 20px;
                text-align: center;
                color: #FFFFFF;
            }

            .sidebar a {
                display: block;
                color: #FFFFFF;
                padding: 10px;
                text-decoration: none;
                font-size: 16px;
                border-radius: 4px;
                transition: background 0.3s ease, color 0.3s ease;
            }

                .sidebar a:hover {
                    background: #FFFFFF;
                    color: #046BCD;
                }

            .sidebar .btn-close {
                background-color: #FF4D4D;
                color: #FFFFFF;
                border: none;
                padding: 10px;
                border-radius: 4px;
                cursor: pointer;
                font-size: 16px;
                text-align: center;
                transition: background-color 0.3s ease;
                margin-top: 20px;
            }

                .sidebar .btn-close:hover {
                    background-color: #CC0000;
                }

        .header {
            position: fixed;
            top: 0;
            left: 250px;
            width: calc(100% - 250px);
            background: #046BCD;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 1000;
            color: #FFFFFF;
        }

            .header .logo {
                font-size: 24px;
                font-weight: bold;
            }

            .header .search-bar input {
                padding: 8px;
                border: 1px solid #D3D3D3;
                border-radius: 4px;
                width: 300px;
            }

            .header .notifications, .header .user-avatar, .header .date-time {
                margin-left: 20px;
            }

                .header .notifications .icon {
                    font-size: 20px;
                    color: #FFFFFF;
                }

                .header .user-avatar img {
                    width: 40px;
                    height: 40px;
                    border-radius: 50%;
                    border: 2px solid #FFFFFF;
                }

            .header .date-time {
                font-size: 16px;
            }

        .main-content {
            margin-left: 250px;
            padding: 20px;
            padding-top: 80px;
        }

        .form-section {
            background: #FFFFFF;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

            .form-section h2 {
                margin-bottom: 20px;
            }

        .form-group label {
            font-weight: bold;
        }

        .btn-save {
            background-color: #046BCD;
            color: #FFFFFF;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            transition: background-color 0.3s ease;
        }

            .btn-save:hover {
                background-color: #0359a8;
            }

        .period-grades {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

            .period-grades .form-group {
                flex: 1 1 11%;
                margin-bottom: 0;
            }

            .period-grades label {
                display: block;
                font-size: 14px;
                margin-bottom: 5px;
            }

            .period-grades input {
                width: 100%;
                max-width: 70px;
            }

        .table-section {
            background: #FFFFFF;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

            .table-section h2 {
                margin-bottom: 20px;
            }

            .table-section table {
                width: 100%;
                border-collapse: collapse;
            }

            .table-section th, .table-section td {
                padding: 10px;
                text-align: left;
                border-bottom: 1px solid #ddd;
            }

            .table-section th {
                background-color: #046BCD;
                color: #FFFFFF;
            }

            .table-section tr:hover {
                background-color: #f5f5f5;
            }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">Sistema EDUDOM</div>
        <a href="/Home" class="nav-link"><i class="fas fa-home"></i>Inicio</a>
        <a href="/Profile" class="nav-link"><i class="fas fa-user"></i>Perfil</a>
        <a href="/Assignment/Index" class="nav-link"><i class="fas fa-tasks"></i>Tareas</a>
        <a href="/Cours/Index" class="nav-link"><i class="fas fa-chalkboard-teacher"></i>Aulas</a>
        <a href="/Qualifications/Index" class="nav-link"><i class="fas fa-star"></i>Calificaciones</a>
        <a href="/Attendance/Index" class="nav-link"><i class="fas fa-user-check"></i>Registro de Asistencia</a>
        <a href="/Reports/Index" class="nav-link"><i class="fas fa-chart-line"></i>Informe de Progreso</a>
        <a href="/Employeer/Index" class="nav-link"><i class="fas fa-users"></i>Empleados</a>
        <a href="/Department/Index" class="nav-link"><i class="fas fa-building"></i>Departamentos</a>
        <a href="/Distric/Index" class="nav-link"><i class="fas fa-map-marker-alt"></i>Distritos</a>
        <a href="/Province/Index" class="nav-link"><i class="fas fa-map"></i>Provincias</a>
        <a href="/School/Index" class="nav-link"><i class="fas fa-school"></i>Escuelas</a>
        <a href="/Subject/Index" class="nav-link"><i class="fas fa-book"></i>Asignaturas</a>
        <a href="/Schedule" class="nav-link"><i class="fas fa-calendar-alt"></i>Horario</a>
        <a href="/Messages" class="nav-link"><i class="fas fa-envelope"></i>Mensajes</a>
        <a href="/Support" class="nav-link"><i class="fas fa-life-ring"></i>Soporte</a>
        <button class="btn-close" onclick="goToLogin()">Cerrar Sección</button>
    </div>
    <div class="header">
        <div class="logo">Sistema EDUDOM</div>
        <div class="search-bar">
            <input type="text" placeholder="Buscar...">
        </div>
        <div class="notifications">
            <i class="fas fa-bell icon"></i>
        </div>
        <div class="user-avatar">
            <img src="https://i.imgur.com/QwhZRyL.png" alt="Avatar">
        </div>
        <div class="date-time">
            <span id="currentDateTime"></span>
        </div>
    </div>
    <div class="main-content">
        <div class="form-section">
            <h2>Asignar Calificación</h2>
            <form method="post" action="/SaveQualification">
                <div class="form-group">
                    <label for="section">Sección</label>
                    <select id="section" name="section" class="form-control" required onchange="updateStudentList()">
                        <option value="">Seleccionar sección</option>
                        <option value="section1">Sección 1</option>
                        <option value="section2">Sección 2</option>
                        <option value="section3">Sección 3</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="student">Estudiante</label>
                    <select id="student" name="student" class="form-control" required>
                        <option value="">Seleccionar estudiante</option>
                    </select>
                </div>
                <!-- Sección de calificaciones por período -->
                <div class="form-group">
                    <label>Calificaciones por Período</label>
                    <div class="period-grades">
                        <!-- Período 1 -->
                        <div class="form-group">
                            <label for="grade-period1">Período 1</label>
                            <input type="number" id="grade-period1" name="grade-period1" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 2 -->
                        <div class="form-group">
                            <label for="grade-period2">Período 2</label>
                            <input type="number" id="grade-period2" name="grade-period2" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 3 -->
                        <div class="form-group">
                            <label for="grade-period3">Período 3</label>
                            <input type="number" id="grade-period3" name="grade-period3" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 4 -->
                        <div class="form-group">
                            <label for="grade-period4">Período 4</label>
                            <input type="number" id="grade-period4" name="grade-period4" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 5 -->
                        <div class="form-group">
                            <label for="grade-period5">Período 5</label>
                            <input type="number" id="grade-period5" name="grade-period5" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 6 -->
                        <div class="form-group">
                            <label for="grade-period6">Período 6</label>
                            <input type="number" id="grade-period6" name="grade-period6" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 7 -->
                        <div class="form-group">
                            <label for="grade-period7">Período 7</label>
                            <input type="number" id="grade-period7" name="grade-period7" step="0.01" min="0" max="100">
                        </div>
                        <!-- Período 8 -->
                        <div class="form-group">
                            <label for="grade-period8">Período 8</label>
                            <input type="number" id="grade-period8" name="grade-period8" step="0.01" min="0" max="100">
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn-save">Guardar</button>
            </form>
        </div>
        <div class="table-section">
            <h2>Lista de Estudiantes</h2>
            <table>
                <thead>
                    <tr>
                        <th>Estudiante</th>
                        <th>Período 1</th>
                        <th>Período 2</th>
                        <th>Período 3</th>
                        <th>Período 4</th>
                        <th>Período 5</th>
                        <th>Período 6</th>
                        <th>Período 7</th>
                        <th>Período 8</th>
                    </tr>
                </thead>
                <tbody id="student-list">
                    <!-- Filas generadas dinámicamente aquí -->
                </tbody>
            </table>
        </div>
    </div>
    <script>
        function goToLogin() {
            window.location.href = '/Account/Logout';
        }

        function updateStudentList() {
            var section = document.getElementById('section').value;
            var studentSelect = document.getElementById('student');
            var studentList = document.getElementById('student-list');

            // Limpiar las opciones actuales
            studentSelect.innerHTML = '<option value="">Seleccionar estudiante</option>';
            studentList.innerHTML = '';

            if (section) {
                // Aquí se podrían cargar los estudiantes basados en la sección seleccionada
                // Por simplicidad, agregamos ejemplos estáticos
                var students = {
                    'section1': [
                        { name: 'Estudiante 1', grades: [85, 90, 78, 88, 92, 85, 80, 87] },
                        { name: 'Estudiante 2', grades: [75, 80, 70, 78, 82, 76, 72, 79] }
                    ],
                    'section2': [
                        { name: 'Estudiante 3', grades: [88, 85, 80, 90, 92, 88, 85, 90] },
                        { name: 'Estudiante 4', grades: [70, 65, 75, 80, 68, 72, 74, 70] }
                    ],
                    'section3': [
                        { name: 'Estudiante 5', grades: [95, 90, 92, 88, 93, 89, 94, 91] },
                        { name: 'Estudiante 6', grades: [80, 85, 78, 82, 84, 80, 75, 77] }
                    ]
                };

                var studentListData = students[section];
                studentListData.forEach(function (student) {
                    var row = document.createElement('tr');
                    row.innerHTML = '<td>' + student.name + '</td>' +
                        student.grades.map(function (grade) {
                            return '<td>' + grade + '</td>';
                        }).join('');
                    studentList.appendChild(row);
                });

                // Llenar el select de estudiantes
                studentListData.forEach(function (student) {
                    var option = document.createElement('option');
                    option.value = student.name;
                    option.text = student.name;
                    studentSelect.add(option);
                });
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            var currentDateTime = new Date().toLocaleString('es-ES', { dateStyle: 'full', timeStyle: 'short' });
            document.getElementById('currentDateTime').textContent = currentDateTime;
        });
    </script>
</body>
</html>
